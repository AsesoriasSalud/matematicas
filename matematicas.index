<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MathPro — Practica Matemáticas</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0f1117;
    --surface: #1a1d27;
    --surface2: #22263a;
    --accent: #7c6ffa;
    --accent2: #fa6f9a;
    --green: #4ade80;
    --red: #f87171;
    --text: #e8eaf6;
    --muted: #8b90b0;
    --border: #2e3250;
    --radius: 16px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Space Grotesk', sans-serif;
    min-height: 100vh;
    padding: 24px 16px 60px;
  }

  /* Header */
  header {
    text-align: center;
    margin-bottom: 40px;
    padding-top: 16px;
  }

  .logo {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 3px;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  h1 {
    font-size: clamp(28px, 6vw, 48px);
    font-weight: 700;
    line-height: 1.1;
    background: linear-gradient(135deg, #fff 0%, var(--accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    color: var(--muted);
    margin-top: 10px;
    font-size: 15px;
  }

  /* Score bar */
  .score-bar {
    display: flex;
    justify-content: center;
    gap: 16px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }

  .score-pill {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 8px 20px;
    font-size: 14px;
    font-weight: 600;
  }

  .score-pill .dot {
    width: 8px; height: 8px;
    border-radius: 50%;
  }

  .dot-green { background: var(--green); }
  .dot-red { background: var(--red); }
  .dot-accent { background: var(--accent); }

  /* Topic selector */
  .topic-selector {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-bottom: 28px;
    flex-wrap: wrap;
  }

  .topic-btn {
    background: var(--surface);
    border: 1.5px solid var(--border);
    color: var(--muted);
    border-radius: 999px;
    padding: 8px 20px;
    font-family: inherit;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  .topic-btn:hover { border-color: var(--accent); color: var(--text); }
  .topic-btn.active {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }

  /* Exercise card */
  .card {
    max-width: 640px;
    margin: 0 auto 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 32px 28px;
    position: relative;
    overflow: hidden;
  }

  .card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--accent), var(--accent2));
  }

  .exercise-tag {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
  }

  .exercise-question {
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(20px, 4vw, 28px);
    font-weight: 600;
    color: #fff;
    margin-bottom: 28px;
    line-height: 1.4;
  }

  .input-row {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }

  .answer-input {
    flex: 1;
    min-width: 0;
    background: var(--surface2);
    border: 1.5px solid var(--border);
    border-radius: 10px;
    color: #fff;
    font-family: 'JetBrains Mono', monospace;
    font-size: 18px;
    padding: 12px 16px;
    outline: none;
    transition: border-color 0.2s;
  }

  .answer-input:focus { border-color: var(--accent); }
  .answer-input.correct { border-color: var(--green); background: rgba(74,222,128,0.07); }
  .answer-input.wrong { border-color: var(--red); background: rgba(248,113,113,0.07); }

  .btn {
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: 10px;
    padding: 12px 24px;
    font-family: inherit;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.1s;
    white-space: nowrap;
  }

  .btn:hover { opacity: 0.88; }
  .btn:active { transform: scale(0.97); }
  .btn.secondary {
    background: var(--surface2);
    border: 1.5px solid var(--border);
    color: var(--text);
  }

  /* Feedback */
  .feedback {
    margin-top: 20px;
    border-radius: 12px;
    padding: 18px 20px;
    display: none;
    animation: fadeIn 0.3s ease;
  }

  @keyframes fadeIn { from { opacity:0; transform:translateY(6px); } to { opacity:1; transform:translateY(0); } }

  .feedback.correct-fb {
    background: rgba(74,222,128,0.1);
    border: 1px solid rgba(74,222,128,0.3);
    display: block;
  }

  .feedback.wrong-fb {
    background: rgba(248,113,113,0.08);
    border: 1px solid rgba(248,113,113,0.25);
    display: block;
  }

  .feedback-title {
    font-weight: 700;
    font-size: 15px;
    margin-bottom: 10px;
  }

  .feedback.correct-fb .feedback-title { color: var(--green); }
  .feedback.wrong-fb .feedback-title { color: var(--red); }

  .step {
    display: flex;
    gap: 12px;
    margin-bottom: 10px;
    align-items: flex-start;
  }

  .step-num {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 2px 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    font-weight: 700;
    color: var(--accent);
    flex-shrink: 0;
    margin-top: 1px;
  }

  .step-text {
    font-size: 14px;
    color: var(--text);
    line-height: 1.5;
    font-family: 'JetBrains Mono', monospace;
  }

  /* Next button row */
  .btn-row {
    display: flex;
    gap: 10px;
    margin-top: 20px;
    flex-wrap: wrap;
  }

  /* Progress */
  .progress-wrap {
    max-width: 640px;
    margin: 0 auto 12px;
  }

  .progress-label {
    display: flex;
    justify-content: space-between;
    font-size: 12px;
    color: var(--muted);
    margin-bottom: 6px;
    font-weight: 600;
  }

  .progress-bar {
    height: 5px;
    background: var(--surface2);
    border-radius: 999px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent), var(--accent2));
    border-radius: 999px;
    transition: width 0.4s ease;
  }

  /* History */
  .history-wrap {
    max-width: 640px;
    margin: 0 auto;
  }

  .history-title {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 12px;
  }

  .history-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .history-item {
    display: flex;
    align-items: center;
    gap: 12px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 10px 16px;
    font-size: 13px;
  }

  .history-icon { font-size: 16px; }
  .history-q { color: var(--muted); flex: 1; font-family: 'JetBrains Mono', monospace; }
  .history-a { font-weight: 700; font-family: 'JetBrains Mono', monospace; }
  .history-item.h-correct .history-a { color: var(--green); }
  .history-item.h-wrong .history-a { color: var(--red); }
</style>
</head>
<body>

<header>
  <div class="logo">▸ MathPro</div>
  <h1>Practica Matemáticas</h1>
  <p class="subtitle">Cálculo · Álgebra · Paso a paso</p>
</header>

<!-- Score -->
<div class="score-bar">
  <div class="score-pill"><span class="dot dot-green"></span> Aciertos: <strong id="score-correct">0</strong></div>
  <div class="score-pill"><span class="dot dot-red"></span> Errores: <strong id="score-wrong">0</strong></div>
  <div class="score-pill"><span class="dot dot-accent"></span> Total: <strong id="score-total">0</strong></div>
</div>

<!-- Topic selector -->
<div class="topic-selector">
  <button class="topic-btn active" onclick="setTopic('calculo')">📐 Cálculo</button>
  <button class="topic-btn" onclick="setTopic('algebra')">🔢 Álgebra</button>
  <button class="topic-btn" onclick="setTopic('ambos')">⚡ Mixto</button>
</div>

<!-- Progress -->
<div class="progress-wrap">
  <div class="progress-label">
    <span>Progreso</span>
    <span id="progress-text">0 / 10</span>
  </div>
  <div class="progress-bar"><div class="progress-fill" id="progress-fill" style="width:0%"></div></div>
</div>

<!-- Exercise card -->
<div class="card" id="exercise-card">
  <div class="exercise-tag" id="ex-tag">Cálculo · Derivadas</div>
  <div class="exercise-question" id="ex-question">Cargando...</div>
  <div class="input-row">
    <input class="answer-input" id="answer-input" type="text" placeholder="Tu respuesta..." autocomplete="off" />
    <button class="btn" onclick="checkAnswer()">Verificar</button>
  </div>
  <div class="feedback" id="feedback">
    <div class="feedback-title" id="fb-title"></div>
    <div id="fb-steps"></div>
  </div>
  <div class="btn-row" id="btn-row" style="display:none">
    <button class="btn" onclick="nextExercise()">Siguiente →</button>
    <button class="btn secondary" onclick="showHint()">💡 Ver solución</button>
  </div>
</div>

<!-- History -->
<div class="history-wrap">
  <div class="history-title">Historial</div>
  <div class="history-list" id="history-list">
    <div style="color:var(--muted);font-size:13px;text-align:center;padding:16px">Aún no has respondido ningún ejercicio.</div>
  </div>
</div>

<script>
// ─── Exercise bank ────────────────────────────────────────────────
const exercises = {
  calculo: [
    {
      tag: 'Cálculo · Derivadas',
      question: 'd/dx [ x³ ] = ?',
      answer: '3x²',
      aliases: ['3x^2','3x2'],
      steps: [
        'Regla de la potencia: d/dx[xⁿ] = n·xⁿ⁻¹',
        'Aquí n = 3, entonces bajamos el 3',
        'd/dx[x³] = 3·x³⁻¹ = 3x²',
        'Respuesta: 3x²'
      ]
    },
    {
      tag: 'Cálculo · Derivadas',
      question: 'd/dx [ 5x² + 2x ] = ?',
      answer: '10x+2',
      aliases: ['10x + 2','10x+2'],
      steps: [
        'Derivamos término a término',
        'd/dx[5x²] = 5·2x = 10x',
        'd/dx[2x]  = 2',
        'Sumamos: 10x + 2'
      ]
    },
    {
      tag: 'Cálculo · Integrales',
      question: '∫ 2x dx = ?',
      answer: 'x²+c',
      aliases: ['x^2+c','x²+C','x^2+C','x² + C','x² + c'],
      steps: [
        'Regla de integración: ∫xⁿ dx = xⁿ⁺¹/(n+1) + C',
        '∫2x dx = 2 · x¹⁺¹/(1+1) + C',
        '= 2 · x²/2 + C',
        '= x² + C'
      ]
    },
    {
      tag: 'Cálculo · Integrales',
      question: '∫ 3x² dx = ?',
      answer: 'x³+c',
      aliases: ['x^3+c','x³+C','x^3+C','x³ + C','x³ + c'],
      steps: [
        '∫3x² dx = 3 · x²⁺¹/(2+1) + C',
        '= 3 · x³/3 + C',
        '= x³ + C'
      ]
    },
    {
      tag: 'Cálculo · Límites',
      question: 'lím (x→2) [ x² - 4 ] = ?',
      answer: '0',
      aliases: ['0'],
      steps: [
        'Sustituimos x = 2 directamente',
        '(2)² - 4 = 4 - 4',
        '= 0'
      ]
    },
    {
      tag: 'Cálculo · Límites',
      question: 'lím (x→3) [ 2x + 1 ] = ?',
      answer: '7',
      aliases: ['7'],
      steps: [
        'Sustituimos x = 3',
        '2(3) + 1 = 6 + 1',
        '= 7'
      ]
    },
    {
      tag: 'Cálculo · Derivadas',
      question: 'd/dx [ sen(x) ] = ?',
      answer: 'cos(x)',
      aliases: ['cos x','cosx','cos(x)'],
      steps: [
        'Es una derivada trigonométrica estándar',
        'd/dx[sen(x)] = cos(x)',
        'Tip: d/dx[cos(x)] = -sen(x) (el opuesto)'
      ]
    },
    {
      tag: 'Cálculo · Integrales',
      question: '∫ cos(x) dx = ?',
      answer: 'sen(x)+c',
      aliases: ['sen(x)+C','sen x + C','sen(x) + C','senx+c','sen(x)+c'],
      steps: [
        'La integral de cos(x) es sen(x) + C',
        'Podemos verificar: d/dx[sen(x)] = cos(x) ✓',
        'Respuesta: sen(x) + C'
      ]
    },
  ],
  algebra: [
    {
      tag: 'Álgebra · Ecuaciones',
      question: 'Resuelve: 2x + 4 = 10',
      answer: '3',
      aliases: ['x=3','x = 3'],
      steps: [
        'Movemos el 4 al otro lado: 2x = 10 - 4',
        '2x = 6',
        'Dividimos entre 2: x = 6/2',
        'x = 3'
      ]
    },
    {
      tag: 'Álgebra · Ecuaciones',
      question: 'Resuelve: 3x - 6 = 9',
      answer: '5',
      aliases: ['x=5','x = 5'],
      steps: [
        'Sumamos 6 en ambos lados: 3x = 9 + 6',
        '3x = 15',
        'Dividimos entre 3: x = 15/3',
        'x = 5'
      ]
    },
    {
      tag: 'Álgebra · Factorización',
      question: 'Factoriza: x² - 9 = ?',
      answer: '(x+3)(x-3)',
      aliases: ['(x-3)(x+3)','(x+3)*(x-3)','(x-3)*(x+3)'],
      steps: [
        'Reconocemos diferencia de cuadrados: a² - b²',
        'a = x, b = 3',
        'Fórmula: (a+b)(a-b)',
        'Respuesta: (x+3)(x-3)'
      ]
    },
    {
      tag: 'Álgebra · Factorización',
      question: 'Factoriza: x² + 5x + 6 = ?',
      answer: '(x+2)(x+3)',
      aliases: ['(x+3)(x+2)'],
      steps: [
        'Buscamos dos números que multipliquen 6 y sumen 5',
        '2 × 3 = 6 ✓  y  2 + 3 = 5 ✓',
        'Factorizamos: (x + 2)(x + 3)'
      ]
    },
    {
      tag: 'Álgebra · Ecuaciones',
      question: 'Resuelve: 5x + 1 = 26',
      answer: '5',
      aliases: ['x=5','x = 5'],
      steps: [
        'Restamos 1: 5x = 26 - 1 = 25',
        'Dividimos entre 5: x = 25/5',
        'x = 5'
      ]
    },
    {
      tag: 'Álgebra · Potencias',
      question: '(x²)³ = ?',
      answer: 'x⁶',
      aliases: ['x^6','x6'],
      steps: [
        'Regla de potencia de potencia: (xᵃ)ᵇ = xᵃ·ᵇ',
        '(x²)³ = x²·³',
        '= x⁶'
      ]
    },
    {
      tag: 'Álgebra · Ecuaciones',
      question: 'Si f(x) = 2x², ¿cuánto es f(3)?',
      answer: '18',
      aliases: ['18'],
      steps: [
        'Sustituimos x = 3 en f(x) = 2x²',
        'f(3) = 2·(3)²',
        '= 2·9',
        '= 18'
      ]
    },
    {
      tag: 'Álgebra · Simplificación',
      question: 'Simplifica: (x³ · x²) = ?',
      answer: 'x⁵',
      aliases: ['x^5','x5'],
      steps: [
        'Regla: xᵃ · xᵇ = xᵃ⁺ᵇ',
        'x³ · x² = x³⁺²',
        '= x⁵'
      ]
    }
  ]
};

// ─── State ────────────────────────────────────────────────────────
let topic = 'calculo';
let pool = [];
let currentEx = null;
let answered = false;
let stats = { correct: 0, wrong: 0, total: 0 };
let history = [];
let sessionCount = 0;

function buildPool() {
  if (topic === 'ambos') {
    pool = [...exercises.calculo, ...exercises.algebra];
  } else {
    pool = [...exercises[topic]];
  }
  pool = pool.sort(() => Math.random() - 0.5);
}

function setTopic(t) {
  topic = t;
  document.querySelectorAll('.topic-btn').forEach((b,i) => {
    b.classList.toggle('active', ['calculo','algebra','ambos'][i] === t);
  });
  buildPool();
  nextExercise();
}

function nextExercise() {
  if (pool.length === 0) buildPool();
  currentEx = pool.pop();
  answered = false;

  document.getElementById('ex-tag').textContent = currentEx.tag;
  document.getElementById('ex-question').textContent = currentEx.question;

  const input = document.getElementById('answer-input');
  input.value = '';
  input.className = 'answer-input';
  input.disabled = false;
  input.focus();

  document.getElementById('feedback').className = 'feedback';
  document.getElementById('btn-row').style.display = 'none';

  sessionCount++;
  updateProgress();
}

function normalize(s) {
  return s.toLowerCase().replace(/\s/g,'').replace(/\^/,'');
}

function checkAnswer() {
  if (answered) return;
  const input = document.getElementById('answer-input');
  const userAns = input.value.trim();
  if (!userAns) return;

  answered = true;
  input.disabled = true;
  stats.total++;

  const correct = normalize(userAns) === normalize(currentEx.answer)
    || (currentEx.aliases || []).some(a => normalize(userAns) === normalize(a));

  const fb = document.getElementById('feedback');
  const fbTitle = document.getElementById('fb-title');
  const fbSteps = document.getElementById('fb-steps');

  if (correct) {
    stats.correct++;
    input.classList.add('correct');
    fb.className = 'feedback correct-fb';
    fbTitle.textContent = '✓ ¡Correcto!';
    fbSteps.innerHTML = renderSteps(currentEx.steps);
    addHistory(true, userAns);
  } else {
    stats.wrong++;
    input.classList.add('wrong');
    fb.className = 'feedback wrong-fb';
    fbTitle.textContent = `✗ Incorrecto — la respuesta es: ${currentEx.answer}`;
    fbSteps.innerHTML = renderSteps(currentEx.steps);
    addHistory(false, userAns);
  }

  updateScores();
  document.getElementById('btn-row').style.display = 'flex';
}

function showHint() {
  if (!answered) {
    answered = true;
    stats.total++;
    stats.wrong++;
    document.getElementById('answer-input').disabled = true;
    const fb = document.getElementById('feedback');
    fb.className = 'feedback wrong-fb';
    document.getElementById('fb-title').textContent = `Solución paso a paso (respuesta: ${currentEx.answer})`;
    document.getElementById('fb-steps').innerHTML = renderSteps(currentEx.steps);
    addHistory(false, '(ver solución)');
    updateScores();
    document.getElementById('btn-row').style.display = 'flex';
  }
}

function renderSteps(steps) {
  return steps.map((s, i) => `
    <div class="step">
      <span class="step-num">paso ${i+1}</span>
      <span class="step-text">${s}</span>
    </div>
  `).join('');
}

function addHistory(correct, ans) {
  history.unshift({ correct, question: currentEx.question, answer: ans, expected: currentEx.answer });
  if (history.length > 8) history.pop();
  renderHistory();
}

function renderHistory() {
  const el = document.getElementById('history-list');
  if (!history.length) { el.innerHTML = '<div style="color:var(--muted);font-size:13px;text-align:center;padding:16px">Aún no has respondido ningún ejercicio.</div>'; return; }
  el.innerHTML = history.map(h => `
    <div class="history-item ${h.correct ? 'h-correct' : 'h-wrong'}">
      <span class="history-icon">${h.correct ? '✅' : '❌'}</span>
      <span class="history-q">${h.question}</span>
      <span class="history-a">${h.correct ? h.answer : h.expected}</span>
    </div>
  `).join('');
}

function updateScores() {
  document.getElementById('score-correct').textContent = stats.correct;
  document.getElementById('score-wrong').textContent = stats.wrong;
  document.getElementById('score-total').textContent = stats.total;
}

function updateProgress() {
  const pct = Math.min((sessionCount % 11) / 10 * 100, 100);
  document.getElementById('progress-fill').style.width = pct + '%';
  document.getElementById('progress-text').textContent = `${sessionCount % 11 || 10} / 10`;
}

// Enter key
document.getElementById('answer-input').addEventListener('keydown', e => {
  if (e.key === 'Enter') {
    if (!answered) checkAnswer();
    else nextExercise();
  }
});

// Init
buildPool();
nextExercise();
sessionCount = 0;
updateProgress();
</script>
</body>
</html>
